{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Humain Kiosk",
  "colors": {
    "primary": "#0E50BD",
    "light": "#9DC2FB",
    "dark": "#1366E2"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "tabler"
  },
  "navbar": {
    "links": [
      {
        "label": "Admin panel",
        "href": "https://app.humain.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://app.humain.ai/register"
    }
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "GitHub",
        "icon": "github",
        "href": "https://github.com/humain-ai"
      }
    ],
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "introduction",
              "concepts/authentication",
              "concepts/session-lifecycle",
              "concepts/modes",
              "concepts/sandbox-mode",
              "concepts/error-codes",
              "concepts/rate-limits"
            ]
          },
          {
            "group": "Connection types",
            "pages": [
              "connections/overview",
              "connections/rest-text",
              "connections/websocket-streaming",
              "connections/webrtc-voice",
              "connections/voip-sip"
            ]
          },
          {
            "group": "Try it out",
            "pages": [
              "playground/text",
              "playground/voice",
              "playground/not-testable"
            ]
          }
        ]
      },
      {
        "tab": "Integrate",
        "groups": [
          {
            "group": "Web",
            "pages": [
              "web/quickstart",
              "web/drop-in-widget",
              "web/react",
              "web/vue",
              "web/svelte",
              "web/vanilla-js",
              "web/streaming-ui",
              "web/customisation"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdks/overview",
              "sdks/python",
              "sdks/go",
              "sdks/dotnet",
              "sdks/swift",
              "sdks/kotlin"
            ]
          },
          {
            "group": "Mobile",
            "pages": [
              "mobile/ios-swift",
              "mobile/android-kotlin",
              "mobile/voice-on-mobile",
              "mobile/audio-session-ios",
              "mobile/audio-session-android"
            ]
          },
          {
            "group": "VoIP & telephony",
            "pages": [
              "voip/overview",
              "voip/sip-gateway",
              "voip/asterisk-agi",
              "voip/asterisk-ari",
              "voip/twilio",
              "voip/vonage",
              "voip/telnyx",
              "voip/codec-guide",
              "voip/troubleshooting"
            ]
          },
          {
            "group": "Plugins",
            "pages": [
              "plugins/wordpress",
              "plugins/freepbx",
              "plugins/3cx"
            ]
          },
          {
            "group": "Embedded",
            "pages": [
              "embedded/overview",
              "embedded/c-library",
              "embedded/raspberry-pi",
              "embedded/freertos",
              "embedded/zephyr",
              "embedded/audio-hardware",
              "embedded/credential-management",
              "embedded/ota-updates"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "openapi.yaml"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/humain-ai"
    }
  },
  "css": "/custom.css"
}
